# CONVEX
# Set to `true` only when you intentionally want to run against the local Convex backend.
USE_LOCAL_CONVEX=false
CONVEX_DEPLOYMENT=...
PUBLIC_CONVEX_URL=...
PUBLIC_CONVEX_SITE_URL=...
# Optional: add a deploy key from Convex Deployment Settings to push code non-interactively.
CONVEX_DEPLOY_KEY=...
CONVEX_API_KEY=...
MAPBOX_ACCESS_TOKEN=...
PUBLIC_MAPBOX_ACCESS_TOKEN=...
PUBLIC_MAPBOX_STYLE_ID=mapbox/navigation-day-v1

# CLERK
CLERK_JWT_ISSUER_DOMAIN=...
PUBLIC_CLERK_PUBLISHABLE_KEY=...
# Optional. If omitted or missing in Clerk, the app falls back to the default Clerk session token.
PUBLIC_CLERK_JWT_TEMPLATE=convex
CLERK_SECRET_KEY=...
